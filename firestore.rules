// Firestore Security Rules for Fire Hydrant System
// Copy and paste this into Firebase Console -> Firestore Database -> Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role == 'admin';
    }

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users collection - allow authenticated users to read their own and admin to read all
    match /users/{userId} {
      // Allow users to read their own document
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow admins to read any user document
      allow read: if isAuthenticated() && isAdmin(request.auth.uid);
      
      // Allow users to write/create their own document
      allow write: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow admins to update any user document
      allow update: if isAuthenticated() && isAdmin(request.auth.uid);
    }

    // Allow reading the entire users collection for admins
    match /users/{document=**} {
      allow read: if isAuthenticated() && isAdmin(request.auth.uid);
    }

    // Add more collections as needed
    // For example, if you have sensor data or logs collections:
    
    // match /sensorData/{document=**} {
    //   allow read: if isAuthenticated();
    //   allow write: if isAuthenticated();
    // }
  }
}
